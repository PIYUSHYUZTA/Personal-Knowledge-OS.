# ============================================================================
# PKOS Backend Configuration
# ============================================================================
# Copy this to .env and set your own values

# Application
APP_NAME=PKOS - Personal Knowledge OS
APP_VERSION=1.0.0-alpha
DEBUG=False

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=False

# Database - PostgreSQL + pgvector
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://pkos_user:pkos_password@localhost:5432/pkos_db

# Vector Store Configuration
VECTOR_STORE_TYPE=pgvector
CHROMADB_PATH=./data/chromadb

# Embedding Model (from sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Security & JWT
SECRET_KEY=your-secret-key-change-in-production-make-it-long-and-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# MPC (Multi-Party Computation) Security - Phase 2
MPC_ENABLED=False
MPC_PRIVATE_KEY=
MPC_SERVER_ENDPOINTS=

# File Upload Configuration
MAX_FILE_SIZE=52428800  # 50 MB in bytes
ALLOWED_EXTENSIONS=pdf,txt,md,docx
UPLOAD_DIR=./data/uploads

# PDF Processing
PDF_EXTRACTION_METHOD=pdfplumber  # or pypdf
OCR_ENABLED=False
TESSERACT_CMD=/usr/bin/tesseract  # Linux/Mac path

# Semantic Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Neo4j Knowledge Graph (Phase 2)
NEO4J_ENABLED=False
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# AURA Configuration
AURA_MODEL_TYPE=local  # local, openai, anthropic
AURA_MAX_CONTEXT_WINDOW=8000
AURA_RESPONSE_TEMPERATURE=0.7

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FORMAT=json  # json or text

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Feature Flags
FEATURE_KNOWLEDGE_GRAPH=True
FEATURE_LIVE_SEARCH=True
FEATURE_AURA_STREAMING=True

# Graph Heatmap Tuning (Phase A - Intelligence)
# Increase multiplier toward 1.0 for slower decay; lower it for faster adaptation.
GRAPH_HEATMAP_NIGHTLY_DECAY_ENABLED=True
GRAPH_HEATMAP_NIGHTLY_DECAY_HOUR_UTC=3
GRAPH_HEATMAP_NIGHTLY_DECAY_MINUTE_UTC=0
GRAPH_HEATMAP_DECAY_INACTIVE_DAYS=7
GRAPH_HEATMAP_DECAY_MULTIPLIER=0.95
GRAPH_HEATMAP_MIN_WEIGHT_FLOOR=0.01
