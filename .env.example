# PKOS Production Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
APP_NAME=PKOS
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
RELOAD=false

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
POSTGRES_DB=pkos
POSTGRES_USER=pkos_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432
SQLALCHEMY_ECHO=false

# ============================================================================
# VECTOR STORE CONFIGURATION
# ============================================================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_STORE_TYPE=pgvector

# ============================================================================
# NEO4J CONFIGURATION (Knowledge Graph)
# ============================================================================
NEO4J_ENABLED=true
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_in_production
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474

# ============================================================================
# REDIS CONFIGURATION (Caching)
# ============================================================================
REDIS_ENABLED=true
REDIS_PASSWORD=change_me_in_production
REDIS_PORT=6379
REDIS_CACHE_TTL=3600

# ============================================================================
# GRAPH HEATMAP TUNING (Intelligence Decay)
# ============================================================================
# Increase multiplier toward 1.0 for slower adaptation, decrease for faster adaptation.
GRAPH_HEATMAP_NIGHTLY_DECAY_ENABLED=true
GRAPH_HEATMAP_NIGHTLY_DECAY_HOUR_UTC=3
GRAPH_HEATMAP_NIGHTLY_DECAY_MINUTE_UTC=0
GRAPH_HEATMAP_DECAY_INACTIVE_DAYS=7
GRAPH_HEATMAP_DECAY_MULTIPLIER=0.95
GRAPH_HEATMAP_MIN_WEIGHT_FLOOR=0.01

# ============================================================================
# LLM PROVIDER CONFIGURATION (REQUIRED FOR PRODUCTION)
# ============================================================================
# You must set at least ONE of these API keys for the system to work

# Anthropic Claude (Recommended as primary)
# Get key from https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-...

# OpenAI GPT-4o (Primary fallback)
# Get key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Google Gemini (Secondary fallback)
# Get key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# ============================================================================
# JWT & AUTHENTICATION
# ============================================================================
JWT_SECRET_KEY=generate_a_secure_random_string_at_least_32_characters_long
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=['http://localhost:3000','https://yourdomain.com']

# ============================================================================
# FILE UPLOADS
# ============================================================================
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=100
KB_BASE_PATH=/app/knowledge_base

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
VITE_API_URL=http://localhost:8000
APP_PORT=3000

# ============================================================================
# DATA PERSISTENCE PATHS (for docker volumes)
# ============================================================================
POSTGRES_DATA_PATH=./data/postgres
NEO4J_DATA_PATH=./data/neo4j/data
NEO4J_LOGS_PATH=./data/neo4j/logs
REDIS_DATA_PATH=./data/redis
UPLOADS_PATH=./data/uploads
KB_PATH=./data/knowledge_base
NGINX_CACHE_PATH=./data/nginx_cache
